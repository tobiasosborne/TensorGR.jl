Cell[BoxData[
 RowBox[{"TexPrintAlignedEquations", "@", "%"}]], "Input",
 CellChangeTimes->{{3.5921334172105207`*^9, 3.5921334204115252`*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"bf785253-4095-48fc-972c-ef5720d39315"],

Cell[BoxData["\<\"\\\\begin{align}\\n(\\\\sCurlDagger_{3,0} \\\\sDiv_{4,1} \\\
\\sCurl_{3,2} U)_{ABA'}={}&\\\\tfrac{2}{3} \\\\Phi^{CD}{}_{A'}{}^{B'} \
(\\\\sCurl_{3,2} U)_{ABCDB'}\\\\nonumber\\\\\\\\\\n& -  \\\\tfrac{5}{3} \
U_{ABCB'C'} (\\\\sCurlDagger_{2,2} \\\\Phi)^{C}{}_{A'}{}^{B'C'}\\n + \
\\\\tfrac{3}{4} (\\\\sCurlDagger_{3,0} \\\\sCurl_{2,1} \\\\sDiv_{3,2} \
U)_{ABA'}\\\\nonumber\\\\\\\\\\n& + \\\\tfrac{10}{9} U_{ABCA'B'} \
(\\\\sDiv_{2,2} \\\\Phi)^{CB'}\\\\nonumber\\\\\\\\\\n& -  \\\\tfrac{5}{2} \
\\\\Phi_{(A}{}^{CB'C'}(\\\\sCurlDagger_{3,2} U)_{B)CA'B'C'}\\\\nonumber\\\\\\\
\\\\n& -  \\\\tfrac{5}{3} \\\\Phi_{(A}{}^{C}{}_{|A'|}{}^{B'}(\\\\sDiv_{3,2} \
U)_{B)CB'}\\\\nonumber\\\\\\\\\\n& -  \\\\tfrac{4}{3} \
U_{(A}{}^{CD}{}_{|A'|}{}^{B'}(\\\\sCurl_{2,2} \\\\Phi)_{B)CDB'}\\\\nonumber\\\
\\\\\\\\n& - 2 U_{(A}{}^{CDB'C'}(\\\\sTwist_{2,2} \
\\\\Phi)_{B)CDA'B'C'}\\\\nonumber\\\\\\\\\\n& + \\\\Phi^{CDB'C'} \
(\\\\sTwist_{3,2} U)_{ABCDA'B'C'}.\\n\\\\end{align}\"\>"], "Output",
 CellChangeTimes->{3.592133421831527*^9, 3.59213373109296*^9, 
  3.592143869822246*^9, 3.5922259558970647`*^9, 3.5981802271189957`*^9, 
