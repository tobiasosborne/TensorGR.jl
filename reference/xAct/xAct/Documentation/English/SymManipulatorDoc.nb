            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"IrrDecomposeCovD[covd[...]@T[...]] produces the \
irreducible decomposition of covd[...]@T[...] using the corresponding \
fundamental operators.\\nIrrDecomposeCovD[T, covd] does the same, but you do \
not have to give any indices.\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"IrrDecomposeCovD", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"xAct`SymManipulator`Private`covd_", "?", 
                    "xAct`SymManipulator`Private`SpacetimeSpinCovDQ"}], "[", 
                    
                    RowBox[{"xAct`SymManipulator`Private`A_", ",", 
                    "xAct`SymManipulator`Private`Adg_"}], "]"}], "[", 
                    RowBox[{
                    
                    RowBox[{"xAct`SymManipulator`Private`TT_", "?", 
                    "xTensorQ"}], "[", "xAct`SymManipulator`Private`inds___", 
                    "]"}], "]"}], ",", 
                    RowBox[{"xAct`SymManipulator`Private`options", ":", 
                    RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"CompatibleSymQ", "[", 
                    RowBox[{
                    
                    RowBox[{"SlotsOfTensor", "[", 
                    "xAct`SymManipulator`Private`TT", "]"}], ",", 
                    
                    RowBox[{"SymmetryGroupOfTensor", "[", 
                    "xAct`SymManipulator`Private`TT", "]"}]}], "]"}], "=!=", 
                    "True"}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"IrrDecomposeCovD", "::", "error"}], 
                    "MessageName"], ",", 
                    "\"Only decompositions of derivatives of symmetric \
tensors are implemented.\""}], "]"}], "]"}], ",", 
                    RowBox[{"With", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"xAct`SymManipulator`Private`eps", "=", 
                    RowBox[{"First", "[", 
                    RowBox[{"MetricsOfVBundle", "[", 
                    RowBox[{
                    
                    RowBox[{"VBundlesOfCovD", "[", 
                    "xAct`SymManipulator`Private`covd", "]"}], 
                    "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
                    "]"}], "]"}]}], ",", 
                    RowBox[{"xAct`SymManipulator`Private`epsdg", "=", 
                    RowBox[{"First", "[", 
                    RowBox[{"MetricsOfVBundle", "[", 
                    RowBox[{
                    
