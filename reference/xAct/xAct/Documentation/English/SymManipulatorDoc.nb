Cell[CellGroupData[{

Cell["Examples with fundamental spinor operators", "SubsubsectionIcon",
 CellChangeTimes->{{3.518749770615905*^9, 3.518749781317524*^9}, {
   3.5441000811725874`*^9, 3.54410009418301*^9}, 3.5449509679572973`*^9, {
