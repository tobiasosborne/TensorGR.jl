    "GiveIndicesToTensor[TT] gives the tensor TT down indices in the correct \
vbundles. A list of vbundles can be given as a second argument. Indices in \
these vbundles will then be up indices.", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, xAct`SymManipulator`GiveIndicesToTensor, {
      xAct`SymManipulator`GiveIndicesToTensor[
         PatternTest[
          Pattern[xAct`SymManipulator`Private`TT, 
           Blank[]], xAct`xTensor`xTensorQ], 
         Optional[
          Pattern[xAct`SymManipulator`Private`upvbundles, 
           Blank[]], {}]] :> Module[{xAct`SymManipulator`Private`n = Length[
            xAct`xTensor`SlotsOfTensor[xAct`SymManipulator`Private`TT]], 
          xAct`SymManipulator`Private`vbundles = Map[xAct`xTensor`UpIndex, 
            xAct`xTensor`SlotsOfTensor[xAct`SymManipulator`Private`TT]], 
          xAct`SymManipulator`Private`gatheredslots, 
          xAct`SymManipulator`Private`inds, 
          xAct`SymManipulator`Private`slotrules}, 
         xAct`SymManipulator`Private`gatheredslots = GatherBy[
            Range[xAct`SymManipulator`Private`n], Part[
            xAct`SymManipulator`Private`vbundles, #]& ]; 
         xAct`SymManipulator`Private`inds = Flatten[
            MapApply[xAct`SymManipulator`GetIndexRange, 
             Map[{
               Length[#], 
               Part[xAct`SymManipulator`Private`vbundles, 
                First[#]]}& , xAct`SymManipulator`Private`gatheredslots]]]; 
         xAct`SymManipulator`Private`inds = Map[If[
             MemberQ[xAct`SymManipulator`Private`upvbundles, 
              xAct`xTensor`VBundleOfIndex[#]], #, 
             xAct`xTensor`DownIndex[#]]& , xAct`SymManipulator`Private`inds]; 
         xAct`SymManipulator`Private`slotrules = 
          Thread[Flatten[xAct`SymManipulator`Private`gatheredslots] -> 
            xAct`SymManipulator`Private`inds]; 
         Apply[xAct`SymManipulator`Private`TT, 
           ReplaceAll[
            Range[xAct`SymManipulator`Private`n], 
            xAct`SymManipulator`Private`slotrules]]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
