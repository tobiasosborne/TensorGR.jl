Cell[BoxData["\<\"\\\\begin{align}\\n(\\\\sdiv_{3} \
\\\\phi)_{A}={}&\\\\nabla^{BC}\\\\phi_{ABC},\\\\\\\\\\n(\\\\scurl_{3} \
\\\\phi)_{ABC}={}&\\\\nabla_{(A}{}^{D}\\\\phi_{BC)D},\\\\\\\\\\n(\\\\stwist_{\
3} \\\\phi)_{ABCDF}={}&\\\\nabla_{(AB}\\\\phi_{CDF)},\\\\\\\\\\n(\\\\isdiv_{3}\
 \\\\phi)_{A}={}&D^{BC}\\\\phi_{ABC},\\\\\\\\\\n(\\\\iscurl_{3} \
\\\\phi)_{ABC}={}&D_{(A}{}^{D}\\\\phi_{BC)D},\\\\\\\\\\n(\\\\istwist_{3} \
\\\\phi)_{ABCDF}={}&D_{(AB}\\\\phi_{CDF)}.\\n\\\\end{align}\"\>"], "Output",
 CellChangeTimes->{3.9596996688555126`*^9, 3.959699837188965*^9, 
  3.959700028384329*^9, 3.959701573882223*^9, 3.9597016252608395`*^9},
 CellLabel->"Out[49]=",ExpressionUUID->"23078c06-1566-e24f-8072-2bb39612ed88"]
}, Open  ]],

