Cell["\<\
Following the definitions in the paper https://arxiv.org/abs/1505.03770,  \
https://doi.org/10.1063/1.4939562, we can work with covariant variations of \
spinors.
We initiate this feature with the following command.\
\>", "MathCaption",
 CellChangeTimes->{{3.8399343510991497`*^9, 3.839934404684333*^9}, {
  3.840007701812069*^9, 3.840007730317093*^9}, {3.9561984849317074`*^9, 
  3.9561984900473423`*^9}, {3.956198531477562*^9, 
  3.9561986859290752`*^9}},ExpressionUUID->"cbdae007-e085-aa49-ae9d-\
2ebdcbb38e70"],

Cell[BoxData[
 RowBox[{"InitVarSH", "[", 
  RowBox[{"CDe", ",", "\"\<G\>\""}], "]"}]], "Input",
 CellLabel->
  "In[111]:=",ExpressionUUID->"ddb98c0c-c2c9-c641-87ec-e21579bb4cf6"],

Cell["\<\
