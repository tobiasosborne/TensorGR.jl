 RowBox[{"phiseries", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"SymSpinor", "[", 
     RowBox[{"0", ",", "0", ",", "\[Phi]"}], "]"}], "==", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"SymMult", "[", 
        RowBox[{
         RowBox[{"SymSpinor", "[", 
          RowBox[{"n", ",", "n", ",", 
           RowBox[{"Subscript", "[", 
            RowBox[{"\[Phi]", ",", "n"}], "]"}]}], "]"}], ",", "n", ",", 
         "n"}], "]"}], "[", 
       RowBox[{"SymSpinor", "[", 
        RowBox[{"n", ",", "n", ",", 
         RowBox[{"Subscript", "[", 
          RowBox[{"p", ",", "n"}], "]"}]}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "3"}], "}"}]}], "]"}]}], "/.", 
