Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", 
    RowBox[{"Subscript", "[", 
     RowBox[{"\[Phi]_", ",", "n_"}], "]"}], "]"}], "^:=", 
   RowBox[{"SubscriptBox", "[", 
    RowBox[{
     RowBox[{"PrintAs", "@", "\[Phi]"}], ",", 
     RowBox[{"PrintAs", "@", "n"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MakeDaggerSymbol", "[", 
    RowBox[{"Subscript", "[", 
     RowBox[{"\[Phi]_", ",", "n_"}], "]"}], "]"}], "^:=", 
   RowBox[{"Subscript", "[", 
    RowBox[{
     RowBox[{"MakeDaggerSymbol", "@", "\[Phi]"}], ",", "n"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Tex", "[", 
    RowBox[{"Subscript", "[", 
     RowBox[{"\[Phi]_", ",", "n_"}], "]"}], "]"}], "^:=", 
   RowBox[{"StringJoin", "[", 
    RowBox[{
     RowBox[{"Tex", "[", "\[Phi]", "]"}], ",", "\"\<_{\>\"", ",", 
     RowBox[{"ToString", "[", "n", "]"}], ",", "\"\<}\>\""}], "]"}]}], 
  ";"}]}], "Input",
