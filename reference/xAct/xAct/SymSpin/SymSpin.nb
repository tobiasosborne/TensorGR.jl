       RowBox[{"1", "/", 
        RowBox[{"CoeffFromMultScal", "[", 
         RowBox[{"tmpexpr", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"tmpexpr", "[", 
