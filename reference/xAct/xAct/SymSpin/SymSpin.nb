Cell["2. General tools", "Subsection",
 InitializationCell->True,
 CellChangeTimes->{{3.5703536834717937`*^9, 3.5703536884170027`*^9}, 
   3.5703540316030054`*^9, {3.570354071211475*^9, 3.570354074799481*^9}, {
