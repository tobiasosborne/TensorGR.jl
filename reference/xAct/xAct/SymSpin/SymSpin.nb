Cell[BoxData[
 RowBox[{
  RowBox[{"CommuteSymMultRuleOutSame", "[", 
   RowBox[{"\[Omega]_", "?", "xTensorQ"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"SymMult", "[", 
     RowBox[{"\[Omega]", ",", "t_", ",", "u_", ",", "spin_"}], "]"}], "[", 
    RowBox[{
     RowBox[{"SymMult", "[", 
      RowBox[{"\[Omega]", ",", "m_", ",", "n_", ",", "spin_"}], "]"}], "[", 
     RowBox[{"\[CurlyPhi]_", "?", "xTensorQ"}], "]"}], "]"}], 
   "\[RuleDelayed]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", "=", 
        RowBox[{
         RowBox[{"NumOfUnprimedSlots", "[", "spin", "]"}], "@", 
         "\[CurlyPhi]"}]}], ",", 
       RowBox[{"l", "=", 
        RowBox[{
         RowBox[{"NumOfPrimedSlots", "[", "spin", "]"}], "@", 
         "\[CurlyPhi]"}]}], ",", 
       RowBox[{"r", "=", 
        RowBox[{
         RowBox[{"NumOfUnprimedSlots", "[", "spin", "]"}], "@", 
         "\[Omega]"}]}], ",", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"NumOfPrimedSlots", "[", "spin", "]"}], "@", 
         "\[Omega]"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"TensorPlus", "@@", 
      RowBox[{"Flatten", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"MultScal", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"SymMultCoeffFunc", "[", 
             RowBox[{"r", ",", "r", ",", "k", ",", "t", ",", "m", ",", "M"}], 
             "]"}], 
            RowBox[{"SymMultCoeffFunc", "[", 
             RowBox[{"s", ",", "s", ",", "l", ",", "u", ",", "n", ",", "NN"}],
              "]"}]}], ",", 
           RowBox[{
            RowBox[{"SymMult", "[", 
             RowBox[{"\[Omega]", ",", 
              RowBox[{"t", "+", "m", "-", "M"}], ",", 
              RowBox[{"u", "+", "n", "-", "NN"}], ",", "spin"}], "]"}], "[", 
            RowBox[{
             RowBox[{"SymMult", "[", 
              RowBox[{"\[Omega]", ",", "M", ",", "NN", ",", "spin"}], "]"}], 
             "[", "\[CurlyPhi]", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"M", ",", 
           RowBox[{"Max", "[", 
            RowBox[{"0", ",", 
             RowBox[{"t", "+", "m", "-", "r"}]}], "]"}], ",", 
           RowBox[{"Min", "[", 
            RowBox[{"r", ",", "k"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"NN", ",", 
           RowBox[{"Max", "[", 
            RowBox[{"0", ",", 
             RowBox[{"u", "+", "n", "-", "s"}]}], "]"}], ",", 
           RowBox[{"Min", "[", 
            RowBox[{"s", ",", "l"}], "]"}]}], "}"}]}], "]"}]}]}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.7767443416703835`*^9, 3.776744443867754*^9}, {
   3.776744778723261*^9, 3.7767447983238773`*^9}, 3.776748202644552*^9, {
