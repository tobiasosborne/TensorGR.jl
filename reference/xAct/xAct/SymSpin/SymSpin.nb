Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SymMultCoeffFunc", "[", 
    RowBox[{"i_", ",", "r_", ",", "k_", ",", "0", ",", "mm_", ",", "MM_"}], 
    "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{"i", ",", "MM"}], "]"}], " ", 
      RowBox[{"Binomial", "[", 
       RowBox[{"mm", ",", "MM"}], "]"}]}], ")"}], "/", 
    RowBox[{"Binomial", "[", 
     RowBox[{
      RowBox[{"1", "+", "i", "+", "k", "-", "MM"}], ",", "MM"}], "]"}]}]}], 
  ";"}]], "Input",
