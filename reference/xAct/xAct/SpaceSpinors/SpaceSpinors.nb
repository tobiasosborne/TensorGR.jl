Cell[BoxData[{
 RowBox[{
  RowBox[{"SpatialTwistMultScal", "[", 
   RowBox[{"covd_", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"T_", "?", "xTensorQ"}], ")"}], "[", "]"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"xAct`SpaceSpinors`Private`TwistName", "@", "covd"}], ")"}], "[", 
   "T", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SpatialTwistMultScal", "[", 
   RowBox[{"covd_", ",", 
    RowBox[{"Times", "[", 
     RowBox[{"a_", ",", "rest__"}], "]"}]}], "]"}], ":=", 
  RowBox[{"TensorPlus", "[", 
   RowBox[{
    RowBox[{"MultScal", "[", 
     RowBox[{
      RowBox[{"Times", "[", "rest", "]"}], ",", 
      RowBox[{"SpatialTwistMultScal", "[", 
       RowBox[{"covd", ",", "a"}], "]"}]}], "]"}], ",", 
    RowBox[{"MultScal", "[", 
     RowBox[{"a", ",", 
      RowBox[{"SpatialTwistMultScal", "[", 
       RowBox[{"covd", ",", 
        RowBox[{"Times", "[", "rest", "]"}]}], "]"}]}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SpatialTwistMultScal", "[", 
   RowBox[{"covd_", ",", 
    RowBox[{"Power", "[", 
     RowBox[{"a_", ",", 
      RowBox[{"c_", "?", "ConstantQ"}]}], "]"}]}], "]"}], ":=", 
  RowBox[{"MultScal", "[", 
   RowBox[{
    RowBox[{"c", "*", 
     RowBox[{"Power", "[", 
