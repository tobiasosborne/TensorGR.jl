Cell[CellGroupData[{

Cell["2.1. Development of some tools", "Subsubsection",
 InitializationCell->True,
 CellChangeTimes->{{3.570354046235831*^9, 
  3.570354067015067*^9}},ExpressionUUID->"187de461-ac77-4df8-8902-\
